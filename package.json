{
  "name": "fastnear-js-monorepo",
  "version": "1.1.0",
  "description": "Easily interact with the NEAR Protocol blockchain",
  "scripts": {
    "type-check": "yarn workspaces foreach --all -t run type-check",
    "build": "yarn workspaces foreach --all -t run build",
    "clean": "yarn workspaces foreach --all -t run clean",
    "install-all": "yarn workspaces foreach --all -t install",
    "install-all:lock": "yarn workspaces foreach --all -t install --refresh-lockfile",
    "pack-all": "yarn workspaces foreach --all -t pack",
    "generate:agent": "node scripts/generate-agent-artifacts.mjs",
    "check:agent": "node scripts/generate-agent-artifacts.mjs --check",
    "test:agent": "yarn check:agent && yarn workspace @fastnear/api build && node scripts/smoke-agent-snippets.mjs",
    "smoke:services:live": "yarn workspace @fastnear/api build && node scripts/smoke-services-live.mjs",
    "smoke:agent:published": "node scripts/smoke-published-agent-surfaces.mjs",
    "test": "vitest run && yarn test:agent"
  },
  "license": "MIT",
  "author": "FastNear",
  "homepage": "https://js.fastnear.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fastnear/js-monorepo.git"
  },
  "keywords": [
    "near-protocol",
    "near-wallet",
    "web3",
    "web3-wallet",
    "fastnearjs",
    "blockchain",
    "fastnear"
  ],
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@fastnear/near-connect": "^0.12.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@walletconnect/sign-client": "^2.23.7",
    "base58-js": "=2.0.0",
    "events": "^3.3.0",
    "js-base64": "^3.7.7"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@types/node": "^22.13.1",
    "http-browserify": "^1.7.0",
    "https-browserify": "^1.0.0",
    "process": "^0.11.10",
    "rimraf": "^6.0.1",
    "stream-browserify": "^3.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.2",
    "vitest": "^3"
  },
  "resolutions": {
    "defu": "^6.1.5",
    "glob": "^10.5.0",
    "h3": "^1.15.9",
    "minimatch": "^9.0.7",
    "picomatch": "^2.3.2",
    "postcss": "^8.5.10",
    "rollup": "^4.59.0",
    "tar": "^7.5.11",
    "vite": "^7.3.2"
  },
  "packageManager": "yarn@4.13.0"
}
