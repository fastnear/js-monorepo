{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist/esm",
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@fastnear/utils": ["../utils/src/index.ts"],
      "@fastnear/wallet": ["../wallet/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../../types/*.d.ts"]
}
